{
  "version": 1,
  "title": "PTG2 PostgreSQL Membership Graph A/B",
  "description": "Compares direct v1 provider membership with the normalized v2 graph using identical full-file input.",
  "scanner_binary": "support/ptg2_scanner/target/release/ptg2_scanner",
  "gates": {
    "min_improvement_pct": 0.0,
    "max_memory_growth_pct": 100.0,
    "min_storage_ratio": 0.0
  },
  "variants": [
    {
      "id": "postgres_binary_v1",
      "expect_serving_row_strategy": "postgres_binary",
      "expect_serving_table_retained": false,
      "expect_serving_table_exists": false,
      "expect_serving_binary_table_exists": true,
      "expect_serving_binary_writer": "rust_stream",
      "expect_serving_sidecar_artifacts": false,
      "api_latency_probe": true,
      "api_latency_max_ms": 100,
      "api_probe_iterations": 20,
      "api_probe_warmup": 4,
      "env": {
        "HLTHPRT_PTG2_SNAPSHOT_ARCH": "postgres_binary_v1",
        "HLTHPRT_PTG2_MANIFEST_PROVIDER_NPI_SIDECAR_ENABLED": "true"
      }
    },
    {
      "id": "postgres_binary_v2",
      "expect_serving_row_strategy": "postgres_binary",
      "expect_serving_table_retained": false,
      "expect_serving_table_exists": false,
      "expect_serving_binary_table_exists": true,
      "expect_serving_binary_writer": "rust_stream",
      "expect_serving_sidecar_artifacts": false,
      "api_latency_probe": true,
      "api_latency_max_ms": 100,
      "api_probe_iterations": 20,
      "api_probe_warmup": 4,
      "env": {
        "HLTHPRT_PTG2_SNAPSHOT_ARCH": "postgres_binary_v2",
        "HLTHPRT_PTG2_MANIFEST_PROVIDER_NPI_SIDECAR_ENABLED": "false"
      }
    }
  ],
