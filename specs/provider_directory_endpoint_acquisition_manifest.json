    "entry_support": {
      "idaho": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-10", "method": "rest", "limitation": "Accepts api-ida-prd.safhir.io cursor continuations with checkpoints."},
      "molina": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "The first unbounded dev run checkpointed 497,700 Location rows before the remote cursor returned HTTP 403. Exact-source checkpoint retries remain selectable even when the immediate retry probe is rejected, so acquisition can resume the durable cursor; terminal endpoint-wide proof remains pending."},
      "michigan": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "PractitionerRole pages are capped at 25. The signed HAPI cursor returns HTTP 403, so the importer validates its shape and advances the endpoint's deterministic _getpagesoffset continuation without replaying the opaque token."},
      "cigna": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-10", "method": "rest", "limitation": "Sequential REST pagination at _count=100 preserves Plan-Net network extensions; _count=75 returns false-empty search sets for role, organization, location, service, and affiliation collections. No Bulk. Expected nonempty initial searches retry transient HTTP-200 empty search sets with cooldowns."},
      "aetna-commercial-medicare": {"support_level": "acquisition-configured", "access_requirement": "oauth2-client-credentials", "requires_registration": true, "reviewed_at": "2026-07-11", "method": "bulk", "limitation": "OAuth2 client credentials and Bulk; Endpoint collection is unavailable. The separate /providerdirectory Medicaid base has 19 credentialed catalog aliases and only targeted search semantics, so it is not treated as another fully enumerable carrier directory."},
      "humana": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Overrides portal or stale paths to the public FHIR base."},
      "iehp": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Normalizes portal and resource paths to the Provider Directory base. The live CapabilityStatement omits HealthcareService and InsurancePlan, but anonymous direct searches and continuations for both are valid."},
      "arkansas": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Uses synthetic _skip pagination with stable _id sorting. PractitionerRole, Practitioner, Organization, and Location are populated; InsurancePlan, HealthcareService, OrganizationAffiliation, and Endpoint currently return valid empty Bundles."},
      "hap": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Rewrites the blocked cursor host and throttles requests to 20 seconds. Initial and rewritten continuation pages were revalidated for all five configured collections."},
      "washington": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Uses standard _count=100 pagination. Populated core collections page successfully, but the latest bounded HealthcareService preflight timed out before a response, so terminal full-acquisition proof remains pending."},
      "wyoming": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Uses standard _count=100 pagination; PractitionerRole pagination was revalidated after the earlier gateway limit was removed."},
      "health-partners-plans": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Uses the official public Provider Directory FHIR catalog base."},
      "amerihealth-nh": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 0900; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "amerihealth-de": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 7100; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "amerihealth-la": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 2100; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "amerihealth-nc": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 1200; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "amerihealth-dc": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 5400; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "amerihealth-pa": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Plan code 0500; full-refresh pages target 250 rows. Anonymous initial and continuation pages were revalidated for the configured resource scope."},
      "horizon-nj": {"support_level": "probe-only", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "probe", "limitation": "Metadata is publicly reachable but declares no resources; core resource searches return HAPI HTTP 403 Access denied by rule, so no pageable acquisition profile is verified."},
      "texas-tmhp": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Seven public collections use stable _id sorting and offset pagination. The live CapabilityStatement omits InsurancePlan, Location, and HealthcareService, but anonymous direct searches for all three succeed. Endpoint is excluded because it is empty."},
      "nebraska": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Seven public collections use stable _id sorting and offset pagination; Endpoint is excluded because it returns HTTP 404."},
      "uhc": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Optum caps five core collections at 10,000 and exposes neither Bulk nor a proven exhaustive residual query. The importer therefore acquires InsurancePlan plus every network-linked PractitionerRole and OrganizationAffiliation, resolves referenced Practitioner, Organization, and Location rows, and requires two identical graph snapshots before publishing plan_graph_complete. collection_complete remains false for the capped raw collections. HealthcareService and Endpoint are excluded."},
      "missouri": {"support_level": "probe-only", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "probe", "limitation": "Metadata declares eight directory resources, but Practitioner timed out and Location continuation pages changed page size and total semantics; no exhaustive acquisition contract is verified."},
      "maine": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Five collections are anonymously readable with ct cursor pagination; InsurancePlan, HealthcareService, and Endpoint are access-gated and excluded."},
      "scan": {"support_level": "probe-only", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "probe", "limitation": "Partitioned Practitioner, Organization, and Location samples plus role reverse lookup work, but every shard has a 100-page cap and full partition completeness is unverified."},
      "centene": {"support_level": "probe-only", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "probe", "limitation": "Metadata and tested resource searches return CloudFront HTTP 403 from dev egress; allowlisting or supported access is required before pagination can be verified."},
      "contra-costa": {"support_level": "acquisition-configured", "access_requirement": "none", "requires_registration": false, "reviewed_at": "2026-07-11", "method": "rest", "limitation": "Seven public collections follow opaque next-link pagination; the official catalog can return 403, so the confirmed fallback base is retained. Endpoint is excluded because its bounded search returns HTTP 400 with a FHIR OperationOutcome stating that the resource type is unsupported."},
      "alohr": {"support_level": "externally-supported", "access_requirement": "private-connector", "requires_registration": true, "reviewed_at": "2026-07-10", "method": "graphql", "documented_resources": ["Practitioner", "Organization", "Location", "PractitionerRole", "OrganizationAffiliation"], "limitation": "FHIR REST reads are auth-gated; the maintained GraphQL connector uses tenant alohr."}
    }
