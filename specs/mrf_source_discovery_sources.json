{
  "default_providers": ["master-list"],
  "test_providers": ["master-list"],
  "providers": {
    "master-list": {
      "parser": "master-list",
      "path": "specs/mrf_payer_master_list.md"
    }
  },
  "platform_resolvers": {
    "aetna_health1": {
      "type": "healthsparq_public_mrf",
      "metadata_url_template": "https://mrf.healthsparq.com/{tenant}-egress.nophi.kyruushsq.com/prd/mrf/{insurerCode}/{brandCode}/latest_metadata.json",
      "tenant_overrides": {
        "MERITAIN_I": "aetnacvs"
      },
      "public_service_path": "/healthsparq/public/service",
      "login_path": "/login",
      "mrf_all_path": "/v2/mrf/all",
      "max_bytes": 52428800
    },
    "healthsparq": {
      "type": "healthsparq_public_mrf",
      "metadata_url_template": "https://mrf.healthsparq.com/{tenant}-egress.nophi.kyruushsq.com/prd/mrf/{insurerCode}/{brandCode}/latest_metadata.json",
      "public_service_path": "/healthsparq/public/service",
      "login_path": "/login",
      "mrf_all_path": "/v2/mrf/all",
      "max_bytes": 52428800
    },
    "highmark_hmhs": {
      "type": "highmark_hmhs_script",
      "script_path": "/js/script.js",
      "max_bytes": 1048576
    },
    "sapphire": {
      "type": "sapphire_html_tocs",
      "max_bytes": 5242880
    },
    "uhc_public_blobs": {
      "type": "uhc_blob_listing",
      "max_bytes": 67108864,
      "path_templates": ["/api/v1/uhc/blobs/"],
      "optum_path_templates": ["/api/v1/oh/blobs/", "/api/v1/orx/blobs/"]
    },
    "bcbsma_monthly_tocs": {
      "type": "bcbsma_monthly_tocs",
      "base_url": "https://transparency-in-coverage.bluecrossma.com/",
      "month_offsets": [0],
      "toc_suffixes": [
        "-01_Blue-Cross-and-Blue-Shield-of-Massachusetts-HMO-Blue-Inc_index.json",
        "-01_Blue-Cross-and-Blue-Shield-of-Massachusetts-Inc_index.json"
      ]
    },
    "cigna_static_mrf_lookup": {
      "type": "cigna_static_mrf_lookup",
      "max_bytes": 5242880,
      "lookup_max_bytes": 2097152,
      "toc_max_bytes": 104857600,
      "lookup_paths": ["/static/mrf/latest.json", "/static/mrf/co/latest.json"]
    },
    "bcbs_asomrf": {
      "type": "bcbs_asomrf_filelist",
      "max_bytes": 5242880,
      "filelist_max_bytes": 20971520,
      "toc_max_bytes": 104857600,
      "max_targets": 250
    }
  }
}
