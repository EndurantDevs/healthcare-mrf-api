# Authenticated inbound operator API. Any external scheduler may use this
# tenant-neutral contract; the engine does not depend on a specific scheduler.
HLTHPRT_CONTROL_API_TOKEN=change-me
HLTHPRT_IMPORT_NODE_ID=local_mrf
# Exhaustive Provider Directory campaigns may span several days. The worker
# and Kubernetes launcher enforce this 144-hour minimum even if the shared
# active-deadline setting is lower.
HLTHPRT_PROVIDER_DIRECTORY_FHIR_JOB_TIMEOUT=518400
# Mandatory persistent root for source-neutral retained acquisition artifacts.
# The service rejects filesystem roots, system temporary trees, and symlinks.
HLTHPRT_PROVIDER_DIRECTORY_ARTIFACT_ROOT=/data/mrf-api/provider-directory-artifacts
# Optional best-effort event sink. Configure the complete HTTPS endpoint and a
# dedicated token; leaving either unset does not affect import execution.
# HLTHPRT_IMPORT_STATUS_EVENT_URL=https://operator.example/v1/import-events
# HLTHPRT_IMPORT_STATUS_EVENT_TOKEN=change-me
HLTHPRT_IMPORT_STATUS_EVENT_QUEUE_SIZE=256
HLTHPRT_IMPORT_STATUS_EVENT_TIMEOUT_SECONDS=1.0
HLTHPRT_IMPORT_STATUS_EVENT_THROTTLE_SECONDS=5.0
HLTHPRT_IMPORT_STATUS_EVENT_TERMINAL_FLUSH_SECONDS=0.25
HLTHPRT_IMPORT_LIVE_PROGRESS_TTL_SECONDS=172800
HLTHPRT_IMPORT_LIVE_PROGRESS_STALE_SECONDS=90
HLTHPRT_IMPORT_LIVE_PROGRESS_HEARTBEAT_SECONDS=15
HLTHPRT_METRICS_REQUIRE_AUTH=1

# Clinical reference terminology import. SNOMED-derived sources are excluded by
# default and require explicit license/compliance review before enabling.
HLTHPRT_CLINICAL_REFERENCE_SOURCES=icd10cm,mesh,rxnorm,medrt
# HLTHPRT_UMLS_API_KEY=
# HLTHPRT_ENABLE_RESTRICTED_TERMINOLOGIES=1
# HLTHPRT_PUBLIC_RESTRICTED_TERMINOLOGIES=1

# Address canonical (deduplicated address archive). The dev-server full-import
# profile above enables canonical writes for all sources. For smaller local
# runs, clear HLTHPRT_ADDRESS_CANON_SOURCES or list only the source under test.
# The Phase 4 reader cutover flag is OFF by default.
# Valid sources: cms_doctors,facility_anchors,provider_enrichment,
# provider_enrollment_ffs,nppes,mrf,pharmacy_license,partd or "all".
# HLTHPRT_ADDRESS_CANON_SOURCES=
# Physical canonical table for resolve helpers (flip to address_archive only
# after the Phase 3 swap):
# HLTHPRT_ADDRESS_ARCHIVE_TABLE=address_archive_v2
# Phase 4 reader cutover: API geocode read/write + NPPES geo backfill use the
# v2 archive only when set. Enable AFTER address-archive-v2-migrate has run
# and its V1/V2/V3 verification queries pass (see docs/devops/address-canonical.md).
# HLTHPRT_ADDRESS_ARCHIVE_CUTOVER=1
# Import resolve dedupes by staged address_key before PostgreSQL materialization;
# tune work_mem/statement_timeout at the calling job, not Python batch size.
# Optional parallelism for canonical address key stamping. Keep this low on
# small local DBs; dev/prod workers can raise it to match available cores.
